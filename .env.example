# 云托管环境变量配置示例
# 复制此文件为 .env 并填写实际值

# Flask 环境 (development/production)
FLASK_ENV=production

# 密钥（用于 session 加密）
SECRET_KEY=your-secret-key-here

# 数据库配置
# 微信云托管会自动注入以下变量，无需手动配置
# MYSQL_ADDON_HOST=mysql host
# MYSQL_ADDON_PORT=3306
# MYSQL_ADDON_USER=root
# MYSQL_ADDON_PASSWORD=password
# MYSQL_ADDON_DB=workload
# MYSQL_ADDON_URI=mysql+pymysql://user:pass@host:port/db

# 如果使用其他数据库，可以配置：
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=password
# DB_NAME=workload

# 文件上传目录
UPLOAD_FOLDER=/tmp/uploads

# 腾讯云 COS 配置（可选，用于存储图片）
# COS_SECRET_ID=your-secret-id
# COS_SECRET_KEY=your-secret-key
# COS_BUCKET=your-bucket-name
# COS_REGION=ap-shanghai
